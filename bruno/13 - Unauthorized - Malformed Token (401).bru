meta {
  name: Unauthorized - Malformed Token (401)
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/notification_events
  body: none
  auth: none
}

headers {
  Authorization: Bearer not.a.valid.jwt.token
}

assert {
  res.status: eq 401
  res.body.code: eq UNAUTHORIZED
  res.body.message: isDefined
  res.body.traceId: isDefined
}
